@model IEnumerable<FurnitureStoreData.Models.Product>
@{
    ViewData["Title"] = "Cửa hàng Nội thất";
}

<div class="container mt-5 pt-4 mb-5">
    <h2 class="text-center fw-bold mb-4">TẤT CẢ SẢN PHẨM</h2>

    <div class="row row-cols-1 row-cols-md-4 g-4 mt-3">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted"><h4>Không tìm thấy sản phẩm nào!</h4></div>
        }
        @foreach (var item in Model)
        {
            <div class="col" data-aos="fade-up" data-aos-anchor-placement="top-bottom">
                <div class="card h-100 border-0 shadow-sm new-product">
                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                        <img src="~/images/products/@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                        <div class="card-body text-center position-relative">
                            <!-- Action Buttons Overlay -->
                            <div class="position-absolute top-0 start-50 translate-middle-x mt-n3 d-flex gap-2 qv-box" style="display: none !important;">
                                <button class="btn btn-sm btn-light shadow-sm rounded-circle qv-btn" 
                                        style="width: 40px; height: 40px;" 
                                        onclick="event.preventDefault(); openQuickView(@item.Id)" title="Xem nhanh">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-light shadow-sm rounded-circle wl-btn" 
                                        style="width: 40px; height: 40px;" 
                                        onclick="event.preventDefault(); addToWishlist(@item.Id)" title="Thêm vào yêu thích">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                            </div>
                            <h5 class="card-title fw-bold text-truncate" title="@item.Name">@item.Name</h5>
                            <p class="card-text text-danger fw-bold">@item.Price.ToString("N0") đ</p>
                        </div>
                    </a>
                    <div class="card-footer bg-white border-0 text-center pb-3">
                        <a asp-controller="Cart" asp-action="Add" asp-route-id="@item.Id" class="btn btn-dark w-100"><i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>