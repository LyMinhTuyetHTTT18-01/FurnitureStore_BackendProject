@model FurnitureStoreData.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
    Layout = "_Layout";
}

<div class="container mt-5 pt-4 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-dark text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Order" asp-action="Index" class="text-dark text-decoration-none">Đơn hàng của tôi</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết ĐH #@Model.Id</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">CHI TIẾT ĐƠN HÀNG #@Model.Id</h2>
        <div>
            @if (Model.Status == 0)
            {
                <span class="badge bg-warning text-dark fs-6 px-3 py-2"><i class="fa-solid fa-clock me-1"></i> Chờ xử lý</span>
            }
            else if (Model.Status == 1)
            {
                <span class="badge bg-info text-dark fs-6 px-3 py-2"><i class="fa-solid fa-truck-fast me-1"></i> Đang giao</span>
            }
            else if (Model.Status == 2)
            {
                <span class="badge bg-success fs-6 px-3 py-2"><i class="fa-solid fa-check-circle me-1"></i> Hoàn thành</span>
            }
            else if (Model.Status == 3)
            {
                <span class="badge bg-danger fs-6 px-3 py-2"><i class="fa-solid fa-times-circle me-1"></i> Đã hủy</span>
            }
        </div>
    </div>

    <div class="row">
        <!-- Thông tin đơn hàng -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold">THÔNG TIN GIAO HÀNG</h5>
                </div>
                <div class="card-body p-4">
                    <p class="mb-2"><i class="fa-regular fa-calendar me-2 text-muted"></i> <strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p class="mb-2"><i class="fa-regular fa-user me-2 text-muted"></i> <strong>Người nhận:</strong> @Model.CustomerName</p>
                    <p class="mb-2"><i class="fa-solid fa-phone me-2 text-muted"></i> <strong>Số điện thoại:</strong> @Model.CustomerPhone</p>
                    <p class="mb-2"><i class="fa-regular fa-envelope me-2 text-muted"></i> <strong>Email:</strong> @Model.CustomerEmail</p>
                    <p class="mb-0"><i class="fa-solid fa-location-dot me-2 text-muted"></i> <strong>Địa chỉ:</strong> @Model.ShippingAddress</p>
                </div>
            </div>
        </div>

        <!-- Danh sách sản phẩm -->
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light py-3 border-bottom">
                    <h5 class="mb-0 fw-bold">SẢN PHẨM ĐÃ MUA</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="bg-light text-muted small border-bottom">
                                <tr>
                                    <th class="ps-4 py-3">Sản phẩm</th>
                                    <th class="py-3 text-center">Đơn giá</th>
                                    <th class="py-3 text-center">Số lượng</th>
                                    <th class="pe-4 py-3 text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderDetails != null)
                                {
                                    @foreach (var detail in Model.OrderDetails)
                                    {
                                        <tr class="border-bottom">
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    @if (detail.Product != null)
                                                    {
                                                        <img src="~/images/products/@(detail.Product.ImageUrl ?? "no-image.png")" alt="@detail.Product.Name" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                                        <div class="ms-3">
                                                            <h6 class="mb-0 fw-bold">
                                                                <a asp-controller="Shop" asp-action="Details" asp-route-id="@detail.ProductId" class="text-dark text-decoration-none">
                                                                    @detail.Product.Name
                                                                </a>
                                                            </h6>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Sản phẩm không tồn tại</span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="text-center">@detail.UnitPrice.ToString("N0") đ</td>
                                            <td class="text-center">@detail.Quantity</td>
                                            <td class="pe-4 text-end text-danger fw-bold">@((detail.UnitPrice * detail.Quantity).ToString("N0")) đ</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot class="bg-light">
                                <tr>
                                    <td colspan="3" class="text-end ps-4 py-3 fs-5 fw-bold">TỔNG CỘNG:</td>
                                    <td class="pe-4 py-3 text-end text-danger fs-5 fw-bold">@Model.TotalAmount.ToString("N0") đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="text-center mt-3">
        <a asp-action="Index" class="btn btn-outline-dark px-4 py-2">
            <i class="fa-solid fa-arrow-left me-2"></i> QUAY LẠI DANH SÁCH
        </a>
    </div>
</div>
