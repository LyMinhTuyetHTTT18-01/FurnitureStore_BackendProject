@model IEnumerable<FurnitureStoreData.Models.Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "_Layout";
}

<div class="container mt-5 pt-4 mb-5">
    <h2 class="fw-bold mb-4">ĐƠN HÀNG CỦA TÔI</h2>

    @if (Model != null && Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="ps-4 py-3">Mã ĐH</th>
                                <th class="py-3">Ngày đặt</th>
                                <th class="py-3">Người nhận</th>
                                <th class="py-3">Tổng tiền</th>
                                <th class="py-3">Trạng thái</th>
                                <th class="pe-4 py-3 text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">#@item.Id</td>
                                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.CustomerName</td>
                                    <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                                    <td>
                                        @if (item.Status == 0)
                                        {
                                            <span class="badge bg-warning text-dark"><i class="fa-solid fa-clock me-1"></i> Chờ xử lý</span>
                                        }
                                        else if (item.Status == 1)
                                        {
                                            <span class="badge bg-info text-dark"><i class="fa-solid fa-truck-fast me-1"></i> Đang giao</span>
                                        }
                                        else if (item.Status == 2)
                                        {
                                            <span class="badge bg-success"><i class="fa-solid fa-check-circle me-1"></i> Hoàn thành</span>
                                        }
                                        else if (item.Status == 3)
                                        {
                                            <span class="badge bg-danger"><i class="fa-solid fa-times-circle me-1"></i> Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Không xác định</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">
                                            <i class="fa-solid fa-eye me-1"></i> Xem chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-box-open fa-5x text-muted mb-4"></i>
            <h4>Bạn chưa có đơn hàng nào!</h4>
            <p class="text-muted">Hãy bắt đầu mua sắm ngay để có thể theo dõi đơn hàng tại đây.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-dark mt-3 px-4">QUAY THẠI CỬA HÀNG</a>
        </div>
    }
</div>
