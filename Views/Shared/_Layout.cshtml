<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FurnitureStoreWeb</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />
    <link rel="stylesheet" href="~/Css/main.css">
    <link rel="stylesheet" href="~/Css/main-moblie.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="header shadow-sm">
        <div class="content d-flex justify-content-between align-items-center px-4 py-2">
            <div class="box-menu-mobile d-lg-none">
                <button class="btn btn-light"><i class="fa-solid fa-bars"></i></button>
            </div>

            <nav class="box-menu d-none d-lg-block">
                <ul class="all-list-menu d-flex list-unstyled m-0 gap-4">
                    <li><a asp-controller="Home" asp-action="Index" class="text-dark fw-bold text-decoration-none">Home</a></li>
                    <li><a asp-controller="Shop" asp-action="Index" class="text-dark fw-bold text-decoration-none">Shop</a></li>

                    @await Component.InvokeAsync("MenuCategories")

                    <li><a asp-controller="Blog" asp-action="Index" class="text-dark fw-bold text-decoration-none">Blog</a></li>
                </ul>
            </nav>

            <div class="box-logo">
                <a asp-controller="Home" asp-action="Index">
                    <img src="~/Picture/logo.png" alt="Logo" style="max-height: 50px;">
                </a>
            </div>

            <div class="box-icon d-flex gap-3 fs-5 align-items-center">

                <form asp-controller="Shop" asp-action="Index" method="get" class="d-flex align-items-center m-0 p-0">
                    <input type="text" name="searchString" class="form-control form-control-sm border-0 bg-light me-1 rounded-pill px-3" placeholder="Tìm sản phẩm..." style="width: 160px; outline: none; box-shadow: none;">
                    <button type="submit" class="btn btn-link text-dark p-0 border-0"><i class="fa-solid fa-magnifying-glass"></i></button>
                </form>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Logout" class="text-danger" title="Đăng xuất khỏi tài khoản @User.Identity.Name">
                        <i class="fa-solid fa-sign-out-alt"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="text-dark" title="Đăng nhập">
                        <i class="fa-regular fa-user"></i>
                    </a>
                }

                <a href="#" class="text-dark"><i class="fa-regular fa-heart"></i></a>

                <a href="#" class="text-dark position-relative" title="Giỏ hàng">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">0</span>
                </a>
            </div>
        </div>
    </div>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <div class="box-first-footer bg-light p-5 mt-5 row">
        <div class="contact col-md-3">
            <h5 class="fw-bold">CONTACT US</h5>
            <div class="in text-muted">
                <p>Add: 4 Copley Place, Boston, MA</p>
                <p>Tell: 866.453.4748</p>
                <p>Email: sales@funorifurniture.com</p>
            </div>
        </div>
        <div class="contact col-md-3">
            <h5 class="fw-bold">CATEGORIES</h5>
            <div class="in d-flex flex-column gap-2 text-muted">
                <a href="#" class="text-decoration-none text-muted">Furniture</a>
                <a href="#" class="text-decoration-none text-muted">Tables</a>
                <a href="#" class="text-decoration-none text-muted">Seating</a>
            </div>
        </div>
        <div class="contact col-md-3">
            <h5 class="fw-bold">SERVICES</h5>
            <div class="in d-flex flex-column gap-2 text-muted">
                <a href="#" class="text-decoration-none text-muted">Sale</a>
                <a href="#" class="text-decoration-none text-muted">Quick Ship</a>
                <a href="#" class="text-decoration-none text-muted">Gift Cards</a>
            </div>
        </div>
        <div class="contact col-md-3">
            <h5 class="fw-bold">JOIN US</h5>
            <div class="input-group mt-3">
                <input type="text" class="form-control" placeholder="Email address...">
                <button class="btn btn-dark"><i class="fa-solid fa-envelope"></i></button>
            </div>
        </div>
    </div>

    <script src="https://kit.fontawesome.com/eda05fcf5c.js" crossorigin="anonymous"></script>
    <script src="~/js/main.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>