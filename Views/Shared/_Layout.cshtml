<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FurnitureStoreWeb</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/Css/main.css">
    <link rel="stylesheet" href="~/Css/main-moblie.css">
    <!-- Thư viện AOS CSS cho hiệu ứng Scroll -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        /* Custom UI / UX Enhancements */
        .new-product {
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            border-radius: 8px;
            overflow: hidden;
        }
        .new-product:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .new-product .btn {
            transition: all 0.3s ease;
        }
        .new-product:hover .btn {
            background-color: #212529 !important;
            color: #fff !important;
        }
        .new-product:hover .qv-btn {
            display: block !important;
        }
        /* Image Zoom Magnifier CSS */
        .zoom-container {
            position: relative;
            overflow: hidden;
            cursor: zoom-in;
        }
        .zoom-img {
             transition: transform 0.3s ease;
        }
        .zoom-container:hover .zoom-img {
            transform: scale(1.5);
            transform-origin: center;
        }
        /* Smooth page transition */
        html {
            scroll-behavior: smooth;
        }
        [data-theme="dark"] .alert {
            background-color: #2d2d2d;
            color: #ffffff;
            border: 1px solid #444;
        }
        [data-theme="dark"] .form-control {
            background-color: #333;
            color: #fff;
            border-color: #444;
        }
        [data-theme="dark"] .btn-light {
            background-color: #444;
            color: #fff;
            border: none;
        }
        [data-theme="dark"] .bg-light {
            background-color: #2d2d2d !important;
        }
        [data-theme="dark"] .text-dark {
            color: #e0e0e0 !important;
        }
        [data-theme="dark"] .shadow-sm {
            box-shadow: 0 .125rem .25rem rgba(255,255,255,.075)!important;
        }
        [data-theme="dark"] .modal-content {
            background-color: #1e1e1e;
            color: #e0e0e0;
        }
        [data-theme="dark"] .card {
            background-color: #2d2d2d;
            color: #e0e0e0;
        }
        [data-theme="dark"] main, [data-theme="dark"] .container-fluid {
            background-color: transparent !important;
        }
        [data-theme="dark"] .box-product-sell-2, [data-theme="dark"] .all-new-product {
            background-color: transparent !important;
        }
    </style>
</head>
<body>
    @Html.AntiForgeryToken()
    <div class="header shadow-sm">
        <div class="content d-flex justify-content-between align-items-center px-4 py-2">
            <div class="box-menu-mobile d-lg-none">
                <button class="btn btn-light"><i class="fa-solid fa-bars"></i></button>
            </div>

            <nav class="box-menu d-none d-lg-block">
                <ul class="all-list-menu d-flex list-unstyled m-0 gap-4">
                    <li><a asp-controller="Home" asp-action="Index" class="text-dark fw-bold text-decoration-none">Home</a></li>
                    <li><a asp-controller="Shop" asp-action="Index" class="text-dark fw-bold text-decoration-none">Shop</a></li>

                    @await Component.InvokeAsync("MenuCategories")

                    <li><a asp-controller="Blog" asp-action="Index" class="text-dark fw-bold text-decoration-none">Blog</a></li>
                </ul>
            </nav>

            <div class="box-logo">
                <a asp-controller="Home" asp-action="Index">
                    <img src="~/Picture/logo.png" alt="Logo" style="max-height: 50px;">
                </a>
            </div>

            <div class="box-icon d-flex gap-3 fs-5 align-items-center">
                <!-- Dark Mode Toggle Button -->
                <button id="theme-toggle" class="btn btn-link text-dark p-0 border-0 me-2" title="Chế độ tối/sáng">
                    <i class="fa-solid fa-moon" id="theme-icon"></i>
                </button>

                <form asp-controller="Shop" asp-action="Index" method="get" class="d-flex align-items-center m-0 p-0">
                    <input type="text" name="searchString" class="form-control form-control-sm border-0 bg-light me-1 rounded-pill px-3" placeholder="Tìm sản phẩm..." style="width: 160px; outline: none; box-shadow: none;">
                    <button type="submit" class="btn btn-link text-dark p-0 border-0"><i class="fa-solid fa-magnifying-glass"></i></button>
                </form>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Order" asp-action="Index" class="text-dark me-2" title="Đơn hàng của tôi">
                        <i class="fa-solid fa-receipt"></i>
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="text-danger" title="Đăng xuất khỏi tài khoản @User.Identity.Name">
                        <i class="fa-solid fa-sign-out-alt"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="text-dark" title="Đăng nhập">
                        <i class="fa-regular fa-user"></i>
                    </a>
                }

                <a asp-controller="Wishlist" asp-action="Index" class="text-dark me-3" title="Danh sách yêu thích">
                    <i class="fa-regular fa-heart"></i>
                </a>

                @{
                    var cartJson = Context.Session.GetString("CartSession");
                    var cartCount = 0;
                    if (!string.IsNullOrEmpty(cartJson))
                    {
                        var cartItems = System.Text.Json.JsonSerializer.Deserialize<List<FurnitureStoreWeb.Models.ViewModels.CartItem>>(cartJson);
                        cartCount = cartItems?.Sum(i => i.Quantity) ?? 0;
                    }
                }
                <a asp-controller="Cart" asp-action="Index" class="text-dark position-relative" title="Giỏ hàng">
                    <i class="fa-solid fa-cart-shopping"></i>
                    @if (cartCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                            @cartCount
                        </span>
                    }
                </a>
            </div>
        </div>
    </div>

    <div class="container-fluid p-0">
        <main role="main">
            @if (TempData["Success"] != null)
            {
                <div class="container mt-3">
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="container mt-3">
                    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" role="alert">
                        <i class="fa-solid fa-circle-exclamation me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <!-- Product Quick View Modal -->
    <div class="modal fade" id="quickViewModal" tabindex="-1" aria-labelledby="quickViewModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-body p-0">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-3 z-3" data-bs-dismiss="modal" aria-label="Close"></button>
                    <div class="row g-0">
                        <div class="col-md-6">
                            <img id="qv-image" src="" class="img-fluid h-100 object-fit-cover" alt="Product Image">
                        </div>
                        <div class="col-md-6 p-4">
                            <span id="qv-category" class="text-muted small text-uppercase"></span>
                            <h3 id="qv-name" class="fw-bold mt-2"></h3>
                            <h4 id="qv-price" class="text-danger fw-bold my-3"></h4>
                            <p id="qv-description" class="text-muted"></p>
                            <div class="mt-4">
                                <a id="qv-add-to-cart" href="#" class="btn btn-dark w-100 py-2">
                                    <i class="fa-solid fa-cart-shopping me-2"></i> Thêm vào giỏ hàng
                                </a>
                                <a id="qv-details" href="#" class="btn btn-outline-secondary w-100 mt-2 py-2">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="box-first-footer bg-light p-5 mt-5 row">
        <div class="contact col-md-3">
            <h5 class="fw-bold">CONTACT US</h5>
            <div class="in text-muted">
                <p>Add: 4 Copley Place, Boston, MA</p>
                <p>Tell: 866.453.4748</p>
                <p>Email: sales@funorifurniture.com</p>
            </div>
        </div>
        <div class="contact col-md-3">
            <h5 class="fw-bold">CATEGORIES</h5>
            <div class="in d-flex flex-column gap-2 text-muted">
                <a href="#" class="text-decoration-none text-muted">Furniture</a>
                <a href="#" class="text-decoration-none text-muted">Tables</a>
                <a href="#" class="text-decoration-none text-muted">Seating</a>
            </div>
        </div>
        <div class="contact col-md-3">
            <h5 class="fw-bold">SERVICES</h5>
            <div class="in d-flex flex-column gap-2 text-muted">
                <a href="#" class="text-decoration-none text-muted">Sale</a>
                <a href="#" class="text-decoration-none text-muted">Quick Ship</a>
                <a href="#" class="text-decoration-none text-muted">Gift Cards</a>
            </div>
        </div>
        <div class="contact col-md-3">
            <h5 class="fw-bold">JOIN US</h5>
            <div class="input-group mt-3">
                <input type="text" class="form-control" placeholder="Email address...">
                <button class="btn btn-dark"><i class="fa-solid fa-envelope"></i></button>
            </div>
        </div>
    </div>

    <script src="https://kit.fontawesome.com/eda05fcf5c.js" crossorigin="anonymous"></script>
    <script src="~/js/main.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- Thư viện AOS JS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Dark Mode Logic
        const themeToggle = document.getElementById('theme-toggle');
        const themeIcon = document.getElementById('theme-icon');
        const currentTheme = localStorage.getItem('theme') || 'light';

        if (currentTheme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            themeIcon.classList.replace('fa-moon', 'fa-sun');
            themeToggle.classList.replace('text-dark', 'text-light');
        }

        themeToggle.addEventListener('click', () => {
            let theme = document.documentElement.getAttribute('data-theme');
            if (theme === 'dark') {
                document.documentElement.removeAttribute('data-theme');
                themeIcon.classList.replace('fa-sun', 'fa-moon');
                themeToggle.classList.replace('text-light', 'text-dark');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                themeIcon.classList.replace('fa-moon', 'fa-sun');
                themeToggle.classList.replace('text-dark', 'text-light');
                localStorage.setItem('theme', 'dark');
            }
        });

        });

        // Quick View Logic
        function openQuickView(productId) {
            $.ajax({
                url: '/Shop/GetQuickView/' + productId,
                type: 'GET',
                success: function (data) {
                    $('#qv-name').text(data.name);
                    $('#qv-price').text(data.price);
                    $('#qv-category').text(data.categoryName || 'Nội thất');
                    $('#qv-description').text(data.description || 'Chưa có mô tả cho sản phẩm này.');
                    $('#qv-image').attr('src', '/images/products/' + data.imageUrl);
                    $('#qv-add-to-cart').attr('href', '/Cart/Add/' + data.id);
                    $('#qv-details').attr('href', '/Shop/Details/' + data.id);
                    
                    var myModal = new bootstrap.Modal(document.getElementById('quickViewModal'));
                    myModal.show();
                },
                error: function () {
                    alert('Không thể tải thông tin sản phẩm. Vui lòng thử lại!');
                }
            });
        }

        function addToWishlist(productId) {
            const token = $('input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '/Wishlist/AddToWishlist',
                type: 'POST',
                data: { productId: productId },
                headers: {
                    "RequestVerificationToken": token
                },
                success: function (response) {
                    alert(response.message);
                },
                error: function () {
                    alert('Bạn cần đăng nhập để thêm sản phẩm vào danh sách yêu thích!');
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>