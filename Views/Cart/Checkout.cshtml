@model FurnitureStoreData.Models.Order
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    Layout = "_Layout";
}

<div class="container mt-5 pt-4 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-dark text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index" class="text-dark text-decoration-none">Giỏ hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Thanh toán</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm" data-aos="fade-right">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold">THÔNG TIN GIAO HÀNG</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Checkout" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CustomerName" class="form-label fw-bold">Họ và tên người nhận</label>
                            <input asp-for="CustomerName" class="form-control" placeholder="Nhập đầy đủ họ tên..." />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CustomerEmail" class="form-label fw-bold">Email</label>
                                <input asp-for="CustomerEmail" class="form-control" placeholder="example@gmail.com" />
                                <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="CustomerPhone" class="form-label fw-bold">Số điện thoại</label>
                                <input asp-for="CustomerPhone" class="form-control" placeholder="Ví dụ: 0987123456" />
                                <span asp-validation-for="CustomerPhone" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ShippingAddress" class="form-label fw-bold">Địa chỉ nhận hàng</label>
                            <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Số nhà, tên đường, phường/xã, quận/huyện..."></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                        </div>

                        <div class="d-grid shadow-sm">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold text-dark p-3">
                                XÁC NHẬN ĐẶT HÀNG
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm sticky-top" style="top: 100px;" data-aos="fade-left">
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 fw-bold">TÓM TẮT ĐƠN HÀNG</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fs-5 fw-bold">TỔNG THANH TOÁN</span>
                        <span class="fs-4 fw-bold text-danger">@ViewBag.Total.ToString("N0") đ</span>
                    </div>
                    
                    <p class="text-muted small">
                        <i class="fa-solid fa-circle-info me-1"></i> 
                        Bằng cách đặt hàng, bạn đồng ý với các chính sách và điều khoản mua sắm của FurnitureStore.
                    </p>
                    
                    <hr>
                    <div class="alert alert-warning border-0 small m-0">
                        <i class="fa-solid fa-truck-fast me-2"></i> Miễn phí vận chuyển cho mọi đơn hàng trong hôm nay!
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
