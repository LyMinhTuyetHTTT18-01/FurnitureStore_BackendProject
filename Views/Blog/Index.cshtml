@model IEnumerable<FurnitureStoreData.Models.Post>
@{
    ViewData["Title"] = "Tin tức Nội thất";
}

<div class="container mt-5 pt-4 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">TIN TỨC & XU HƯỚNG</h2>
        <p class="text-muted">Cập nhật những xu hướng thiết kế nội thất mới nhất</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted"><h5>Hiện tại chưa có bài viết nào!</h5></div>
        }
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                    <a asp-controller="Blog" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                        <img src="~/images/posts/@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 250px; object-fit: cover;">
                        <div class="card-body p-4">
                            <div class="text-muted mb-2" style="font-size: 0.85rem;">
                                <i class="fa-regular fa-calendar me-1"></i> @item.CreatedAt.ToString("dd/MM/yyyy")
                                <i class="fa-regular fa-user ms-3 me-1"></i> @(item.AppUser?.FullName ?? "Admin")
                            </div>
                            <h5 class="card-title fw-bold">@item.Title</h5>
                            <p class="card-text text-muted mt-3">
                                @(item.Content.Length > 100 ? item.Content.Substring(0, 100) + "..." : item.Content)
                            </p>
                            <span class="text-primary fw-bold text-uppercase" style="font-size: 0.85rem;">Đọc tiếp <i class="fa-solid fa-arrow-right ms-1"></i></span>
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
</div>