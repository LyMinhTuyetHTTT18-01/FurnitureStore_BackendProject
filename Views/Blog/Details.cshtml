@model FurnitureStoreData.Models.Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5 pt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-dark text-decoration-none">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Blog" asp-action="Index" class="text-dark text-decoration-none">Blog</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Tin tức</li>
                </ol>
            </nav>

            <h1 class="fw-bold mb-3">@Model.Title</h1>

            <div class="text-muted mb-4 pb-3 border-bottom d-flex align-items-center gap-3">
                <span><i class="fa-regular fa-calendar-alt me-1"></i> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                <span><i class="fa-solid fa-pen-nib me-1"></i> Đăng bởi: <strong>@(Model.AppUser?.FullName ?? "Quản trị viên")</strong></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="~/images/posts/@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded mb-4 shadow-sm w-100" style="max-height: 500px; object-fit: cover;" />
            }

            <div class="post-content" style="line-height: 1.8; font-size: 1.1rem; text-align: justify;">
                @Html.Raw(Model.Content.Replace("\n", "<br/>"))
            </div>

            <div class="mt-5 pt-4 border-top">
                <h5 class="fw-bold mb-3">Chia sẻ bài viết:</h5>
                <a href="#" class="btn btn-outline-primary me-2"><i class="fa-brands fa-facebook-f"></i> Facebook</a>
                <a href="#" class="btn btn-outline-info"><i class="fa-brands fa-twitter"></i> Twitter</a>
            </div>
        </div>
    </div>
</div>