@{
    ViewData["Title"] = "Đăng nhập bằng Email OTP";
    Layout = "_Layout";
}

<div class="container mt-5 mb-5" style="min-height: 50vh;" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-md-5 mt-5">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0"><i class="fa-solid fa-envelope-circle-check me-2"></i> Xác thực qua Email</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-controller="Account" asp-action="SendOtp" method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold">Địa chỉ Email</label>
                            <input type="email" name="email" class="form-control form-control-lg" required placeholder="Nhập Email đã đăng ký..." />
                            <small class="text-muted mt-2 d-block">
                                <i class="fa-solid fa-circle-info"></i> Chúng tôi sẽ gửi một mã số 6 chữ số đến hòm thư của bạn để lấy quyền truy cập.
                            </small>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold text-dark">
                                GỬI MÃ XÁC THỰC
                            </button>
                        </div>
                        
                        <div class="text-center mt-3">
                            <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-muted">
                                <i class="fa-solid fa-arrow-left me-1"></i> Trở về trang Đăng nhập
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
