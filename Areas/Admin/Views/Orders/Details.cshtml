@model FurnitureStoreData.Models.Order

@{
    ViewData["Title"] = "Chi tiết Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Chi tiết Đơn hàng: <span class="text-primary">DH@(Model.Id.ToString("0000"))</span></h1>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        <div class="row">
            <div class="col-md-4">
                <div class="card shadow">
                    <div class="card-header bg-light"><h3 class="card-title fw-bold">Thông tin Khách hàng</h3></div>
                    <div class="card-body">
                        <p><strong>Khách hàng:</strong> @Model.CustomerName</p>
                        <p><strong>Điện thoại:</strong> @Model.CustomerPhone</p>
                        <p><strong>Email:</strong> @Model.CustomerEmail</p>
                        <p><strong>Địa chỉ giao:</strong> @Model.ShippingAddress</p>
                        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        <hr />
                        <form asp-action="UpdateStatus" method="post" class="d-flex align-items-center">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <select name="status" class="form-control form-control-sm mr-2">
                                <option value="0" selected="@(Model.Status == 0)">Chờ xử lý</option>
                                <option value="1" selected="@(Model.Status == 1)">Đang giao</option>
                                <option value="2" selected="@(Model.Status == 2)">Hoàn thành</option>
                                <option value="3" selected="@(Model.Status == 3)">Đã hủy</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary text-nowrap">Cập nhật</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-light"><h3 class="card-title fw-bold">Sản phẩm đã đặt</h3></div>
                    <div class="card-body p-0">
                        <table class="table table-bordered mb-0 text-center">
                            <thead class="bg-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Hình ảnh</th>
                                    <th>Đơn giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderDetails != null)
                                {
                                    foreach (var detail in Model.OrderDetails)
                                    {
                                        <tr>
                                            <td class="fw-bold text-left">@(detail.Product?.Name ?? "Sản phẩm đã xóa")</td>
                                            <td>
                                                @if (detail.Product != null)
                                                {
                                                    <img src="~/images/products/@detail.Product.ImageUrl" style="width: 50px; height: 50px; object-fit: cover;" class="rounded" />
                                                }
                                            </td>
                                            <td>@detail.UnitPrice.ToString("N0") đ</td>
                                            <td>@detail.Quantity</td>
                                            <td class="text-danger fw-bold">@( (detail.UnitPrice * detail.Quantity).ToString("N0") ) đ</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="4" class="text-right h5">TỔNG CỘNG:</th>
                                    <th class="text-danger h5 fw-bold">@Model.TotalAmount.ToString("N0") đ</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
        </div>
    </div>
</section>