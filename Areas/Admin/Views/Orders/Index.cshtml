@model IEnumerable<FurnitureStoreData.Models.Order>

@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header"><div class="container-fluid"><h1 class="m-0">Danh sách Đơn hàng</h1></div></div>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow">
            <div class="card-body table-responsive p-0">
                <table class="table table-hover table-bordered text-center">
                    <thead class="bg-light">
                        <tr>
                            <th>Mã Đơn</th>
                            <th>Ngày đặt</th>
                            <th>Khách hàng</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="6">Chưa có đơn hàng nào.</td></tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">DH@(item.Id.ToString("0000"))</td>
                                <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.CustomerName</td>
                                <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") đ</td>
                                <td>
                                    @if (item.Status == 2)
                                    {
                                        <span class="badge bg-success">Hoàn thành</span>
                                    }
                                    else if (item.Status == 1)
                                    {

                                        <span class="badge bg-info">Đang giao</span>
                                    }
                                    else if (item.Status == 3)
                                    {

                                        <span class="badge bg-secondary">Đã hủy</span>
                                    }
                                    else
                                    {

                                        <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info"><i class="fas fa-eye"></i> Xem</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>