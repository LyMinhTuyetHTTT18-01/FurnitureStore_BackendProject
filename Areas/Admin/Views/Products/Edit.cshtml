@model FurnitureStoreData.Models.Product

@{
    ViewData["Title"] = "Sửa Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header"><div class="container-fluid"><h1 class="m-0">Sửa Sản phẩm</h1></div></div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-warning shadow">
            <div class="card-header"><h3 class="card-title">Cập nhật thông tin</h3></div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div class="card-body">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="form-group mb-3">
                        <label class="fw-bold">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="fw-bold">Giá bán</label>
                            <input asp-for="Price" type="number" class="form-control" required min="0" />
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label class="fw-bold">Danh mục</label>
                            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group mb-3">
                        <label class="fw-bold d-block">Hình ảnh hiện tại</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="~/images/products/@Model.ImageUrl" style="width:100px; height:100px; object-fit:cover;" class="rounded border mb-2" />
                        }
                        <input type="file" name="imageFile" class="form-control" accept="image/*">
                        <small class="text-muted">Chỉ chọn ảnh mới nếu bạn muốn thay đổi ảnh cũ.</small>
                    </div>
                </div>

                <div class="card-footer bg-white">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="fas fa-save me-1"></i> Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</section>