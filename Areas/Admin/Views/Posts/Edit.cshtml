@model FurnitureStoreData.Models.Post
@{
    ViewData["Title"] = "Sửa Bài viết";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header"><div class="container-fluid"><h1 class="m-0">Sửa Bài viết</h1></div></div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-warning shadow">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div class="card-body">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="AppUserId" />

                    <div class="row">
                        <div class="col-md-9">
                            <div class="form-group mb-3">
                                <label class="fw-bold">Tiêu đề bài viết <span class="text-danger">*</span></label>
                                <input asp-for="Title" class="form-control form-control-lg" required />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="fw-bold">Nội dung <span class="text-danger">*</span></label>
                                <textarea asp-for="Content" class="form-control" rows="12" required></textarea>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-3">
                                <label class="fw-bold d-block">Trạng thái</label>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsPublished">
                                    <label class="form-check-label fw-bold @(Model.IsPublished ? "text-success" : "text-secondary")">
                                        @(Model.IsPublished ? "Đang xuất bản" : "Bản nháp")
                                    </label>
                                </div>
                            </div>
                            <hr />
                            <div class="form-group mb-3">
                                <label class="fw-bold d-block">Ảnh bìa hiện tại</label>
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="~/images/posts/@Model.ImageUrl" style="width: 100%; height: auto; object-fit: cover;" class="rounded border mb-2 shadow-sm" />
                                }
                                <input type="file" name="imageFile" class="form-control mt-2" accept="image/*">
                                <small class="text-muted">Chỉ chọn file nếu bạn muốn thay đổi ảnh cũ.</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer text-end bg-white">
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy bỏ</a>
                    <button type="submit" class="btn btn-warning fw-bold"><i class="fas fa-save me-1"></i> Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</section>