@model FurnitureStoreData.Models.Post
@{
    ViewData["Title"] = "Viết bài mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header"><div class="container-fluid"><h1 class="m-0">Viết bài mới</h1></div></div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-success shadow">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-9">
                            <div class="form-group mb-3">
                                <label class="fw-bold">Tiêu đề bài viết <span class="text-danger">*</span></label>
                                <input asp-for="Title" class="form-control form-control-lg" placeholder="Nhập tiêu đề..." required />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label class="fw-bold">Nội dung <span class="text-danger">*</span></label>
                                <textarea asp-for="Content" class="form-control" rows="12" placeholder="Nội dung bài viết..." required></textarea>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-group mb-3">
                                <label class="fw-bold d-block">Trạng thái</label>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" asp-for="IsPublished" checked>
                                    <label class="form-check-label text-success fw-bold">Xuất bản ngay</label>
                                </div>
                            </div>
                            <hr />
                            <div class="form-group mb-3">
                                <label class="fw-bold">Ảnh bìa</label>
                                <input type="file" name="imageFile" class="form-control" accept="image/*">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer text-end bg-white">
                    <a asp-action="Index" class="btn btn-secondary me-2">Hủy bỏ</a>
                    <button type="submit" class="btn btn-success fw-bold"><i class="fas fa-paper-plane me-1"></i> Đăng bài</button>
                </div>
            </form>
        </div>
    </div>
</section>