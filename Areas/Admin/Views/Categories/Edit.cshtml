@model FurnitureStoreData.Models.Category

@{
    ViewData["Title"] = "Sửa Danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-header"><div class="container-fluid"><h1 class="m-0">Sửa Danh mục</h1></div></div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-warning shadow">
            <div class="card-header"><h3 class="card-title">Cập nhật thông tin</h3></div>

            <form asp-action="Edit" method="post">
                <div class="card-body">
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3">
                        <label class="fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="card-footer bg-white">
                    <button type="submit" class="btn btn-warning fw-bold"><i class="fas fa-save me-1"></i> Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</section>